#!/usr/bin/env sh
# xinitrc du poste de déploiement Odroid-M1 (mode kiosque).
#
# Lancé par `startx` depuis le service systemd `odroid-station.service`. Pas de
# gestionnaire de fenêtres (l'app tourne en plein écran, inutile d'en installer
# un sur une image minimale) : X sert uniquement de surface d'affichage pour
# station_gui.py.
set -eu

# Pas de mise en veille/écran noir sur un poste qui doit rester lisible en continu.
xset -dpms
xset s off
xset s noblank

exec python3 "$(dirname "$0")/../tools/station_gui.py"
